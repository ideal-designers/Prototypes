{
  "buildCommand": "npm run build:proto",
  "outputDirectory": "dist/fvdr-prototypes/browser",
  "framework": null,
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": { "X-Content-Type-Options": "nosniff" },
      "continue": true
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY"
      },
      "dest": "/index.html"
    }
  ]
}
